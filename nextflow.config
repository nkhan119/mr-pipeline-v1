// ================================================================
//  nextflow.config — MR Pipeline CDC 1.0.0
//  Author : Nadeem Khan, Bioinformatician, INRS-CAFSB
//  GitHub : github.com/nkhan119
// ================================================================

manifest {
    name            = 'mr-pipeline-v1'
    author          = 'Nadeem Khan, INRS-CAFSB'
    description     = 'Two-cohort MR pipeline: rsID map → uvMR → heterogeneity → MVMR → HTML report'
    version         = '1.0.0'
    nextflowVersion = '>=23.04'
    mainScript      = 'main.nf'
    homePage        = 'https://github.com/nkhan119'
}

// ── Parameters ─────────────────────────────────────────────────
params {
    // ═══════════════════════════════════════════════════════════
    // EDIT THIS ONE PATH — everything else derives from it
    // ═══════════════════════════════════════════════════════════
    base_dir       = "/home/nadeem/Downloads/1000G_phase3_common_norel"

    // Derived paths — no need to edit these
    sumstat_dir    = "${params.base_dir}/GWAS_analysis/gwas"
    ref_bim_dir    = "${params.base_dir}"
    ref_panel      = "${params.base_dir}/1000G_phase3_common_norel"

    // Output
    out_dir        = "${projectDir}/results"

    // Cohort names
    cohorts        = "Cohort_A,Cohort_B"

    // ── Causal pairs ─────────────────────────────────────────
    // Format: "exposure:outcome:p_exp:label"
    uvmr_pairs = "ldl_cholesterol:cad:5e-8:LDL->CAD,bmi:t2d:5e-8:BMI->T2D,bmi:hypertension:5e-8:BMI->HTN,crp_log:cad:1e-5:CRP->CAD,ldl_cholesterol:t2d:5e-8:LDL->T2D"

    // Format: "exp1+exp2:p1+p2:outcome:label"
    mvmr_pairs = "ldl_cholesterol+bmi:5e-8+5e-8:cad:LDL+BMI->CAD,ldl_cholesterol+bmi:5e-8+5e-8:t2d:LDL+BMI->T2D,bmi+crp_log:5e-8+1e-5:cad:BMI+CRP->CAD"

    // ── MR parameters ────────────────────────────────────────
    clump_r2        = 0.001
    clump_kb        = 10000
    f_stat_min      = 10
    min_instruments = 2
    presso_n_dist   = 1000

    // ── Skip flags ───────────────────────────────────────────
    skip_uvmr   = false
    skip_het    = false
    skip_mvmr   = false
    skip_report = false

    // ── Report metadata ──────────────────────────────────────
    author      = "Nadeem Khan"
    affiliation = "Bioinformatician"
    institute   = "INRS-Centre Armand-Frappier Sante-Biotechnologie, Laval, QC, Canada"
    github      = "github.com/nkhan119"

    // ── OpenGWAS token (optional — for server-side LD clumping)
    opengwas_token = "../1000G_phase3_common_norel/token.txt"

    // ── Compute ──────────────────────────────────────────────
    threads = 8
}

// ── Docker image ─────────────────────────────────────────────────
// Build locally:  docker build -t nkhan119/mr-pipeline:1.0.0 .
// Push to hub:    docker push nkhan119/mr-pipeline:1.0.0
// Pull on Narval: singularity pull docker://nkhan119/mr-pipeline:1.0.0
def docker_image = "nkhan119/mr-pipeline:1.0.0"

// ── Process resource labels ──────────────────────────────────────
process {
    withLabel: 'small'  { cpus = 2;  memory = { 8.GB  * task.attempt }; time = '2h'  }
    withLabel: 'medium' { cpus = 4;  memory = { 16.GB * task.attempt }; time = '6h'  }
    withLabel: 'large'  { cpus = 8;  memory = { 32.GB * task.attempt }; time = '12h' }

    errorStrategy = { task.exitStatus in [130, 137, 143] ? 'retry' : 'finish' }
    maxRetries    = 2
}

// ── Profiles ─────────────────────────────────────────────────────
profiles {

    // ── RECOMMENDED: Docker (no conda install issues) ──────────
    // Usage: nextflow run main.nf -profile local,docker -resume
    docker {
        docker.enabled         = true
        docker.runOptions      = "-v /home/nadeem/Downloads:/home/nadeem/Downloads"
        docker.fixOwnership    = true
        singularity.enabled    = false
        conda.enabled          = false
        process.container      = docker_image
    }

    // ── HPC / Narval: Singularity from Docker Hub ──────────────
    // Usage: nextflow run main.nf -profile narval,singularity -resume
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "$HOME/.singularity/cache"
        docker.enabled         = false
        conda.enabled          = false
        process.container      = docker_image
    }

    // ── Fallback: conda (may fail on TwoSampleMR/MVMR) ────────
    // Usage: nextflow run main.nf -profile local,conda -resume
    conda {
        conda.enabled       = true
        conda.useMamba      = false
        docker.enabled      = false
        singularity.enabled = false
        process {
            withLabel: 'small'  { conda = "${projectDir}/envs/mr_env.yaml" }
            withLabel: 'medium' { conda = "${projectDir}/envs/mr_env.yaml" }
            withLabel: 'large'  { conda = "${projectDir}/envs/mr_env.yaml" }
        }
    }

    // ── Executor profiles (combine with container profile) ─────
    local {
        process.executor = 'local'
    }

    narval {
        process.executor       = 'slurm'
        process.clusterOptions = '--account=def-fveyrier'
        process.queue          = 'def-fveyrier_cpu'
    }

    cc {
        // Beluga / Cedar / Graham
        process.executor       = 'slurm'
        process.clusterOptions = '--account=def-fveyrier'
    }
}

// ── Execution reports ────────────────────────────────────────────
def ts = new java.text.SimpleDateFormat("yyyyMMdd_HHmm").format(new Date())
trace    { enabled = true; file = "${params.out_dir}/logs/trace_${ts}.txt";      overwrite = true }
report   { enabled = true; file = "${params.out_dir}/logs/nf_report_${ts}.html"; overwrite = true }
timeline { enabled = true; file = "${params.out_dir}/logs/timeline_${ts}.html";  overwrite = true }
dag      { enabled = true; file = "${params.out_dir}/logs/dag.svg";              overwrite = true }
